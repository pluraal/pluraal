{
  "name": "pluraal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pluraal": "./dist/cli.js"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:links": "remark --frail .",
    "lint": "npm run lint:md && npm run lint:links",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "tsx src/cli.ts test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "markdownlint-cli2": "^0.17.2",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
